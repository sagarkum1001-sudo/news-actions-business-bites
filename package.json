{
  "name": "news-actions-business-bites",
  "version": "1.0.0",
  "description": "Cross-platform news aggregation and analysis app",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "echo 'Build not required for server'",
    "mobile:android": "cd mobile && npx react-native run-android",
    "mobile:ios": "cd mobile && npx react-native run-ios",
    "mobile:start": "cd mobile && npx react-native start",
    "mobile:build:android": "cd mobile && cd android && ./gradlew assembleRelease",
    "mobile:build:ios": "cd mobile && cd ios && xcodebuild -workspace NewsActions.xcworkspace -scheme NewsActions -configuration Release -sdk iphoneos -archivePath build/NewsActions.xcarchive archive",
    "lint": "eslint .",
    "format": "prettier --write .",
    "export-data": "node scripts/export-json.js",
    "deploy:local": "./scripts/deploy-local.sh",
    "watchlist:discover": "python3 watchlist_news_fetcher.py"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "axios": "^1.6.2",
    "@supabase/supabase-js": "^2.38.4",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "news",
    "aggregation",
    "analysis",
    "finance",
    "business",
    "react-native",
    "cross-platform"
  ],
  "author": "News Actions Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagarkum1001-sudo/news-actions-business-bites.git"
  },
  "workspaces": [
    "mobile"
  ]
}
