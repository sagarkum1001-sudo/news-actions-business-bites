{
  "version": 2,
  "functions": {
    "server/index.js": {
      "includeFiles": [
        "db/data.db**"
      ]
    }
  },
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server/index.js"
    }
  ]
}
