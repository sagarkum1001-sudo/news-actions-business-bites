{
  "version": 2,
  "functions": {
    "server/index.js": {
      "runtime": "@vercel/node",
      "includeFiles": [
        "db/data.db**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/server/index.js"
    }
  ]
}
