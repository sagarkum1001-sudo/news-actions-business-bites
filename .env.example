# News Actions Server Environment Configuration

# Database Configuration
# Choose one of the following:

# For Supabase (Production)
USE_SUPABASE=true
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# For local SQLite (Development)
USE_SQLITE=true
DATABASE_PATH=./db.sqlite3

# Server Configuration
NODE_ENV=development
PORT=3000

# Authentication Configuration
# Google OAuth (leave empty for demo mode)
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Demo Mode (always enabled if Google auth is disabled)
DEMO_MODE_ENABLED=true

# Feature Flags
WATCHLIST_ENABLED=true
USER_ASSIST_ENABLED=true
READ_LATER_ENABLED=true
SEARCH_ENABLED=true
WATCHLIST_NEWS_DISCOVERY=true

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_TIMEOUT_MINUTES=1440

# External APIs (if any)
NEWS_API_KEY=
SEARCH_API_KEY=

# Logging
LOG_LEVEL=info
# Options: debug, info, warn, error

# Rate Limiting (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS (allowed origins - comma separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
