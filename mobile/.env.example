# News Actions Mobile App Environment Configuration

# API Configuration
API_BASE_URL=http://localhost:3000
# For production, use your deployed server URL:
# API_BASE_URL=https://your-app-name.vercel.app

# App Configuration
APP_ENV=development
# Options: development, staging, production

# Feature Flags (override server defaults if needed)
ENABLE_WATCHLIST=true
ENABLE_USER_ASSIST=true
ENABLE_SEARCH=true
ENABLE_READ_LATER=true

# Analytics (future use)
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=

# Push Notifications (future use)
PUSH_NOTIFICATIONS_ENABLED=false
FCM_SERVER_KEY=

# Offline Sync (future use)
OFFLINE_SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=15

# Debug Settings
LOG_LEVEL=info
# Options: debug, info, warn, error
